figuras = []
figura_nova = None
estado_atual = EstadoLinha()  # Estado inicial padrão


def atualizar_estado(*args):
    """Muda a classe do estado atual dependendo da escolha no OptionMenu."""
    global estado_atual
    mapa_estados = {
        'Linha': EstadoLinha(),
        'Rabisco': EstadoRabisco(),
        'Circulo': EstadoCirculo(),
        'Retangulo': EstadoRetangulo(),
        'Oval': EstadoOval()
    }
    tipo = tipo_figura_var.get()
    estado_atual = mapa_estados.get(tipo, EstadoLinha())


def mudar_cor_fig(nova_cor):
    global cor_atual
    mapa_cores = {
        "Preto": "black",
        "Vermelho": "red",
        "Azul": "blue",
        "Verde": "green",
        "Amarelo": "yellow",
        "Roxo": "purple",
    }
    cor_atual = mapa_cores.get(nova_cor, "black")
    desenhar_figuras()


def fazer_as_figuras_finais():
    """Valida e adiciona a nova figura criada à lista permanente."""
    global figura_nova
    if figura_nova is not None and not figura_nova.figura_imcompleta():
        figuras.append(figura_nova)
    figura_nova = None
    desenhar_figuras()


def desenhar_figuras():
    canvas.delete("all")
    for fig in figuras:
        fig.desenhar(canvas, cor=cor_atual)
    if figura_nova is not None:
        figura_nova.desenhar(canvas, cor=cor_atual)


# Redirecionamento dos eventos do Tkinter para o Estado Atual ativo
def iniciar_figura_nova(event):
    estado_atual.pressionar(event)


def atualizar_figura_nova(event):
    estado_atual.arrastar(event)
    desenhar_figuras()


def incluir_figura_nova(event):
    estado_atual.soltar(event)

